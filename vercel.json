{
  "version": 2,
  "builds": [
    {
      "src": "Movie-Recommendation-System-master/movie_recommendation/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.10"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "Movie-Recommendation-System-master/movie_recommendation/wsgi.py"
    }
  ],
  "installCommand": "cd Movie-Recommendation-System-master && pip install -r requirements.txt",
  "buildCommand": "cd Movie-Recommendation-System-master && python manage.py collectstatic --noinput"
}
